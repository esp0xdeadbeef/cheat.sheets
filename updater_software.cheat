% update cheatsheet

# update this flake's inputs
nix flake update

# run Burp Suite Community from this flake
NIXPKGS_ALLOW_UNFREE=1 nix shell --impure github:esp0xdeadbeef/cheat.sheets#burpsuite-community -c burpsuite

# run Burp Suite Professional from this flake
NIXPKGS_ALLOW_UNFREE=1 nix shell --impure github:esp0xdeadbeef/cheat.sheets#burpsuite-pro -c burpsuite
