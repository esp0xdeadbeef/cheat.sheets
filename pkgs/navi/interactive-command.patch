+++ b/shell/navi.plugin.bash	2026-06-23 06:45:10.980713225 +0200
@@ -1,13 +1,40 @@
 #!/usr/bin/env bash
 
 _navi_call() {
-   local result="$(navi "$@" </dev/tty)"
+   local result="$(command navi "$@" </dev/tty)"
    printf "%s" "$result"
 }
 
+_navi_passthrough() {
+   case "${1:-}" in
+      repo|widget|info|fn|help|-h|--help|-V|--version|--print)
+         return 0
+         ;;
+   esac
+
+   [[ $- != *i* || ! -t 0 || ! -t 1 ]]
+}
+
+navi() {
+   if _navi_passthrough "$@"; then
+      command navi "$@"
+      return
+   fi
+
+   local output
+   output="$(_navi_call --print "$@")" || return
+
+   if [[ -n "$READLINE_LINE" || -n "$READLINE_POINT" ]]; then
+      READLINE_LINE="$output"
+      READLINE_POINT=${#READLINE_LINE}
+   else
+      printf "%s\n" "$output"
+   fi
+}
+
 _navi_widget() {
    local -r input="${READLINE_LINE}"
-   local -r last_command="$(echo "${input}" | navi fn widget::last_command)"
+   local -r last_command="$(echo "${input}" | command navi fn widget::last_command)"
 
    if [ -z "${last_command}" ]; then
       local -r output="$(_navi_call --print)"
