% update navi

# update esp0xdeadbeef repo
NIXPKGS_ALLOW_UNFREE=1 nix shell --impure -I nixpkgs=channel:nixos-unstable nixpkgs#navi -c navi repo add esp0xdeadbeef/cheat.sheets

# update infosec streams
NIXPKGS_ALLOW_UNFREE=1 nix shell --impure -I nixpkgs=channel:nixos-unstable nixpkgs#navi -c navi repo add infosecstreams/cheat.sheets


